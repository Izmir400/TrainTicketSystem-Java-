<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane style="-fx-background-color: linear-gradient(to bottom, #0f2027, #203a43, #2c5364);"
            xmlns="http://javafx.com/javafx/25" 
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="application.SupportController">

    <!-- Top Bar -->
    <top>
        <HBox style="-fx-padding: 15; -fx-background-color: rgba(0,0,0,0.3);">
            <Label style="-fx-text-fill: #00ffff; -fx-font-size: 24; -fx-font-weight: bold;" 
                   text="🎧 Customer Support" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="backButton" onAction="#onBackToDashboard" 
                    style="-fx-background-color: #00ffff; -fx-text-fill: #0f2027; -fx-font-weight: bold;"
                    text="← Back to Dashboard" />
        </HBox>
    </top>

    <!-- Center Content -->
    <center>
        <VBox spacing="30" style="-fx-padding: 40;" alignment="CENTER">
            <Label style="-fx-text-fill: white; -fx-font-size: 22;" 
                   text="How can we help you today?" />

            <!-- Input area -->
            <TextArea fx:id="messageArea" promptText="Write your message or question here..." 
                      prefHeight="150" style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white;" />

            <!-- Buttons -->
            <HBox spacing="20" alignment="CENTER">
                <Button fx:id="sendButton" onAction="#onSendMessage" 
                        style="-fx-background-color: #00ffff; -fx-text-fill: #0f2027; -fx-font-weight: bold; -fx-padding: 12 40;"
                        text="Send Message" />

                <Button fx:id="callButton" onAction="#onCallSupport" 
                        style="-fx-background-color: #ffaa00; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 30;"
                        text="📞 Call Support" />
            </HBox>

            <!-- Output area: history of sent messages -->
            <Label style="-fx-text-fill: #00ffcc; -fx-font-size: 18; -fx-font-weight: bold;" 
                   text="Message History:" />

            <ListView fx:id="messageHistory" prefHeight="200" 
                      style="-fx-background-color: rgba(255,255,255,0.08); -fx-text-fill: white;" />
        </VBox>
    </center>
</BorderPane>
