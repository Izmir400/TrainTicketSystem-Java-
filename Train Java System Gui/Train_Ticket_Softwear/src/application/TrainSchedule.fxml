<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="application.TrainScheduleController">

    <top>
        <VBox spacing="12" alignment="CENTER" style="-fx-background-color: #2C3E50; -fx-padding: 20;">
            <Label text="Train Schedule" style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;"/>
            
            <HBox spacing="10" alignment="CENTER">
                <TextField fx:id="departureField" promptText="Nga (p.sh. Tiranë)" prefWidth="170"/>
                <TextField fx:id="arrivalField"   promptText="Në (p.sh. Durrës)" prefWidth="170"/>
                <DatePicker fx:id="datePicker"/>
                
                <Button text="Kërko" onAction="#searchTrains" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
                <Button text="Rifresko" onAction="#refreshTable" style="-fx-background-color: #7f8c8d; -fx-text-fill: white;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <!-- FIX: përdor fx:constant për resize policy -->
        <TableView fx:id="scheduleTable">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="trainIdCol" text="ID" minWidth="60"/>
                <TableColumn fx:id="trainNameCol" text="Emri i Trenit" minWidth="160"/>
                <TableColumn fx:id="departureStationCol" text="Nisja" minWidth="130"/>
                <TableColumn fx:id="departureTimeCol" text="Ora Nisjes" minWidth="100"/>
                <TableColumn fx:id="arrivalStationCol" text="Arritja" minWidth="130"/>
                <TableColumn fx:id="arrivalTimeCol" text="Ora Arritjes" minWidth="100"/>
                <TableColumn fx:id="availableSeatsCol" text="Vende të lira" minWidth="110"/>
                <TableColumn fx:id="priceCol" text="Çmimi (€)" minWidth="90"/>
                <TableColumn fx:id="actionCol" text="Veprim" minWidth="110"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 15; -fx-background-color: #ECF0F1;">
            <Label fx:id="statusLabel" text="Gati..."/>
            <Button text="Kthehu" onAction="#goBack" 
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;"/>
        </HBox>
    </bottom>
</BorderPane>
