<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="application.PaymentController"
            style="-fx-background-color: linear-gradient(to bottom, #203a43, #2c5364);">

    <center>
        <VBox alignment="CENTER" spacing="15" style="-fx-padding: 30;">
            <!-- Title -->
            <Label text="💳 Payment"
                   style="-fx-text-fill: #00ffff; -fx-font-size: 24; -fx-font-weight: bold;" />

            <!-- Payment fields -->
            <TextField fx:id="cardNumberField" promptText="Card Number"
                       style="-fx-background-color: transparent; -fx-border-color: #00ffff; -fx-text-fill: white;" />

            <HBox spacing="10">
                <TextField fx:id="expiryField" promptText="MM/YY"
                           style="-fx-background-color: transparent; -fx-border-color: #00ffff; -fx-text-fill: white;" />
                <TextField fx:id="cvvField" promptText="CVV"
                           style="-fx-background-color: transparent; -fx-border-color: #00ffff; -fx-text-fill: white;" />
            </HBox>

            <TextField fx:id="nameField" promptText="Cardholder Name"
                       style="-fx-background-color: transparent; -fx-border-color: #00ffff; -fx-text-fill: white;" />

            <!-- Buttons -->
            <HBox alignment="CENTER" spacing="15">
                <Button fx:id="payButton" text="Confirm Payment" onAction="#onPayClick"
                        style="-fx-background-color: #00ffcc; -fx-text-fill: #0f2027; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 20;" />

                <Button fx:id="printBillButton" text="🖨 Print Bill" onAction="#onPrintBillClick"
                        style="-fx-background-color: #00ffcc; -fx-text-fill: #0f2027; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 20;" />
            </HBox>
        </VBox>
    </center>
</BorderPane>
