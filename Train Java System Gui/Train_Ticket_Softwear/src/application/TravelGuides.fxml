<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="application.TravelGuidesController"
            style="-fx-background-color: linear-gradient(to bottom, #0f2027, #203a43, #2c5364);">

    <!-- Top Bar -->
    <top>
        <HBox spacing="15" style="-fx-padding: 15; -fx-background-color: rgba(0,0,0,0.4); -fx-alignment: CENTER_LEFT;">
            <Label text="🌍 Travel Guides &amp; Tips" 
                   style="-fx-text-fill: #00ffff; -fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="backButton" text="← Back to Dashboard" 
                    onAction="#goBack"
                    style="-fx-background-color: #00ffff; -fx-text-fill: #0f2027; -fx-font-weight: bold; -fx-background-radius: 6;"/>
        </HBox>
    </top>

    <!-- Center Content -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <VBox spacing="30" style="-fx-padding: 30;">
                
                <!-- Title -->
                <Label text="Discover Albania by Train" 
                       style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold; -fx-effect: dropshadow(gaussian, black, 4, 0.5, 0, 2);"/>

                <!-- Guide Cards Row 1 -->
                <HBox spacing="25" alignment="CENTER">
                    <!-- Guide 1 -->
                    <VBox spacing="10" style="-fx-background-color: rgba(255,255,255,0.12); -fx-padding: 15; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, black, 6, 0.3, 0, 2);">
                        <Label text="🏙️ Tirana to Durrës" style="-fx-text-fill: #00ffcc; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                        <Label text="• Coastal city with beautiful beaches&#10;• Ideal for a day trip&#10;• Visit the Amphitheatre and Port" 
                               style="-fx-text-fill: white; -fx-wrap-text: true;"/>
                    </VBox>

                    <!-- Guide 2 -->
                    <VBox spacing="10" style="-fx-background-color: rgba(255,255,255,0.12); -fx-padding: 15; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, black, 6, 0.3, 0, 2);">
                        <Label text="🏔️ Tirana to Shkodra" style="-fx-text-fill: #00ffcc; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                        <Label text="• Historic city near Lake Shkodra&#10;• Visit Rozafa Castle&#10;• Great for nature lovers" 
                               style="-fx-text-fill: white; -fx-wrap-text: true;"/>
                    </VBox>
                </HBox>

                <!-- Guide Cards Row 2 -->
                <HBox spacing="25" alignment="CENTER">
                    <!-- Guide 3 -->
                    <VBox spacing="10" style="-fx-background-color: rgba(255,255,255,0.12); -fx-padding: 15; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, black, 6, 0.3, 0, 2);">
                        <Label text="🌊 Vlora Route" style="-fx-text-fill: #00ffcc; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                        <Label text="• Beautiful Adriatic coastline&#10;• Famous for its beaches and seafood&#10;• Independence Monument" 
                               style="-fx-text-fill: white; -fx-wrap-text: true;"/>
                    </VBox>

                    <!-- Guide 4 -->
                    <VBox spacing="10" style="-fx-background-color: rgba(255,255,255,0.12); -fx-padding: 15; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, black, 6, 0.3, 0, 2);">
                        <Label text="⛰️ Korça Region" style="-fx-text-fill: #00ffcc; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                        <Label text="• Cultural capital of Albania&#10;• Famous for traditional music and wine&#10;• Beautiful mountain scenery" 
                               style="-fx-text-fill: white; -fx-wrap-text: true;"/>
                    </VBox>
                </HBox>

                <!-- Tips Section -->
                <VBox spacing="12" style="-fx-background-color: rgba(255,255,255,0.08); -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, black, 6, 0.3, 0, 2);">
                    <Label text="✨ Travel Tips" style="-fx-text-fill: #ffd700; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Label text="• Book your tickets in advance during summer&#10;• Arrive 15-20 minutes before departure&#10;• Keep your ticket until the end of journey&#10;• Most trains have limited food options" 
                           style="-fx-text-fill: white; -fx-wrap-text: true;"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <!-- Bottom Status -->
    <bottom>
        <HBox style="-fx-padding: 12; -fx-background-color: rgba(0,0,0,0.3); -fx-alignment: CENTER;">
            <Label text="More guides and interactive maps coming soon..." 
                   style="-fx-text-fill: #aaaaaa; -fx-font-style: italic;"/>
        </HBox>
    </bottom>

</BorderPane>
