<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane style="-fx-background-color: linear-gradient(to bottom, #0f2027, #203a43, #2c5364);"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="application.SignupController">

    <children>
        <VBox alignment="CENTER"
              prefHeight="588.0"
              prefWidth="701.0"
              spacing="15"
              style="-fx-background-color: rgba(255,255,255,0.1);
                     -fx-background-radius: 15;
                     -fx-padding: 30;
                     -fx-effect: dropshadow(gaussian, #00ffff, 20, 0.5, 0, 0);">

            <Label style="-fx-text-fill: #00ffff; -fx-font-size: 22; -fx-font-weight: bold;"
                   text="Create Account" />

            <TextField fx:id="usernameField"
                       promptText="Username"
                       style="-fx-background-color: transparent;
                              -fx-border-color: #00ffff;
                              -fx-border-radius: 8;
                              -fx-text-fill: white;" />

            <PasswordField fx:id="passwordField"
                           promptText="Password"
                           style="-fx-background-color: transparent;
                                  -fx-border-color: #00ffff;
                                  -fx-border-radius: 8;
                                  -fx-text-fill: white;" />

            <PasswordField fx:id="confirmPasswordField"
                           promptText="Confirm Password"
                           style="-fx-background-color: transparent;
                                  -fx-border-color: #00ffff;
                                  -fx-border-radius: 8;
                                  -fx-text-fill: white;" />

            <!-- Fixed Button -->
            <Button fx:id="signupButton"
                    text="Sign Up"
                    onAction="#onSignupClick"
                    style="-fx-background-color: #00ffff;
                           -fx-text-fill: #0f2027;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-padding: 8 20;" />

            <Hyperlink fx:id="loginLink"
                       onAction="#onLoginLinkClick"
                       style="-fx-text-fill: #00ffff;"
                       text="Already have an account? Log in" />
        </VBox>
    </children>
</AnchorPane>
